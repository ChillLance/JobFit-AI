# Copy to `.env.local` for local secrets (never commit `.env.local`).
# All keys are optional — without them, only the free local rule-based
# analysis runs. Each AI provider activates as soon as its key is present.

# Gemini deep analysis (POST /api/jobs/[id]/analyze/deep)
GEMINI_API_KEY=

# Groq Llama 70B analysis (POST /api/jobs/[id]/analyze/groq)
GROQ_API_KEY=
# Optional model override (default: llama-3.3-70b-versatile)
GROQ_MODEL=

# OpenRouter analysis (POST /api/jobs/[id]/analyze/openrouter)
# One API key gives access to many models: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional model override (default: meta-llama/llama-3.3-70b-instruct)
OPENROUTER_MODEL=

# Analysis mode: `local` (default) = free rule-based screening.
ANALYZE_MODE=local

# Public demo deployment (e.g. Vercel free tier) — see docs/DEPLOYMENT.md §6.
# Swaps job/profile storage for an in-memory store seeded from
# data/demo-jobs.json, so the app never touches node:sqlite (some serverless
# Node runtimes don't ship it) and never needs a persistent disk. Data resets
# whenever the serverless instance restarts. Leave both unset/false for
# normal (SQLite-backed) local development and self-hosted deployments.
DEMO_MODE=false
# Client-visible copy of the flag above (shows the demo banner in the UI).
# Must match DEMO_MODE — Next.js only inlines NEXT_PUBLIC_* vars into the
# browser bundle, so the server flag alone won't toggle the banner.
NEXT_PUBLIC_DEMO_MODE=false
